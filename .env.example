# =============================================================================
# NEUM LEX COUNSEL — Environment Configuration Template
# =============================================================================
#
# USAGE:
#   cp .env.example .env
#   Edit .env with your actual values
#   NEVER commit .env to version control
#
# REQUIRED vs OPTIONAL:
#   [REQUIRED]  — App will not start without this value
#   [OPTIONAL]  — Has a default; can be omitted in development
#   [SECRET]    — Must be generated securely; never use example values in production
#
# GENERATING SECRETS:
#   JWT secret:         openssl rand -hex 64
#   TOTP encryption:    python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   Postgres password:  openssl rand -base64 32
#   Redis password:     openssl rand -base64 32
#
# =============================================================================


# =============================================================================
# APPLICATION
# =============================================================================

# [REQUIRED] Environment name — controls OpenAPI visibility, debug output, HSTS
# Values: development | staging | production
ENVIRONMENT=development

# [OPTIONAL] Application version — shown in /health and OpenAPI docs
APP_VERSION=1.0.0

# [OPTIONAL] Log level
# Values: DEBUG | INFO | WARNING | ERROR
# Use DEBUG locally, INFO in staging, WARNING in production
LOG_LEVEL=INFO

# [OPTIONAL] Echo SQL queries to console — NEVER enable in production (leaks data)
SQL_ECHO=false


# =============================================================================
# DATABASE (PostgreSQL 16)
# =============================================================================

# [REQUIRED] Full async database URL for SQLAlchemy + asyncpg
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://nlc_user:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/nlc_db

# [OPTIONAL] Sync URL for Alembic migrations (auto-derived from DATABASE_URL if not set)
# Only needed if you run alembic outside Docker (e.g. from local machine pointing at remote DB)
# DATABASE_URL_SYNC=postgresql://nlc_user:CHANGE_ME_POSTGRES_PASSWORD@localhost:5432/nlc_db

# PostgreSQL credentials (used by docker-compose postgres service)
POSTGRES_DB=nlc_db
POSTGRES_USER=nlc_user
# [SECRET] Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# [OPTIONAL] Host port for postgres container (dev only — remove in production)
POSTGRES_EXTERNAL_PORT=5432

# [OPTIONAL] Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600


# =============================================================================
# JWT AUTHENTICATION
# =============================================================================

# [SECRET][REQUIRED] JWT signing secret — MUST be changed in production
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64

# [OPTIONAL] JWT algorithm — do not change unless you know what you're doing
JWT_ALGORITHM=HS256

# [OPTIONAL] Access token lifetime in minutes (default: 60 = 1 hour)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# [OPTIONAL] Refresh token lifetime in days (default: 7)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# [OPTIONAL] Temporary 2FA token lifetime in minutes (between step 1 and step 2 of login)
JWT_TEMP_TOKEN_EXPIRE_MINUTES=5


# =============================================================================
# TOTP / TWO-FACTOR AUTHENTICATION
# =============================================================================

# [OPTIONAL] Issuer name shown in authenticator apps (e.g. Google Authenticator)
TOTP_ISSUER=Neum Lex Counsel

# [SECRET][REQUIRED] Fernet key for AES-256-GCM encryption of TOTP secrets at rest
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_FERNET_GENERATE_KEY


# =============================================================================
# SECURITY
# =============================================================================

# [OPTIONAL] Max consecutive failed login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# [OPTIONAL] Lockout duration in minutes after too many failed attempts
LOCKOUT_MINUTES=30

# [OPTIONAL] Login endpoint rate limit (format: "N/period" where period: second|minute|hour|day)
RATE_LIMIT_LOGIN=10/minute

# [OPTIONAL] General API rate limit per IP
RATE_LIMIT_API=200/minute

# [OPTIONAL] IP whitelist for Super Admin endpoints (comma-separated)
# Leave blank to allow from any IP (development only)
# Example: SUPER_ADMIN_IP_WHITELIST=203.0.113.0/24,198.51.100.1
SUPER_ADMIN_IP_WHITELIST=


# =============================================================================
# CORS
# =============================================================================

# [REQUIRED] Comma-separated list of allowed CORS origins
# Development: http://localhost:3000,http://localhost:5173
# Production: https://app.neumlexcounsel.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# [OPTIONAL] Allowed hosts for TrustedHostMiddleware (production only)
ALLOWED_HOSTS=localhost,127.0.0.1

# [OPTIONAL] External port for API container (dev only)
API_EXTERNAL_PORT=8000

# [OPTIONAL] Number of uvicorn workers (use 1 for Celery compat; scale via replicas)
API_WORKERS=1


# =============================================================================
# REDIS
# =============================================================================

# [REQUIRED] Redis connection URL
# Format: redis://:PASSWORD@HOST:PORT/DB_NUMBER
# DB 0 = default (Celery broker + result backend)
# DB 1 = redbeat beat schedule
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# [SECRET][REQUIRED] Redis password
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# [OPTIONAL] Max Redis memory for LRU eviction
REDIS_MAXMEMORY=256mb

# [OPTIONAL] Max Redis connection pool size
REDIS_MAX_CONNECTIONS=20

# [OPTIONAL] Host port for redis container (dev only)
REDIS_EXTERNAL_PORT=6379

# [OPTIONAL] Celery broker URL (defaults to REDIS_URL if not set)
# CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# [OPTIONAL] Celery result backend (defaults to REDIS_URL if not set)
# CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0


# =============================================================================
# CELERY WORKERS
# =============================================================================

# [OPTIONAL] Number of concurrent Celery worker processes
CELERY_CONCURRENCY=4

# [OPTIONAL] Flower admin username
FLOWER_USER=nlcadmin

# [SECRET] Flower admin password
FLOWER_PASSWORD=CHANGE_ME_FLOWER_PASSWORD

# [OPTIONAL] External port for Flower UI
FLOWER_EXTERNAL_PORT=5555


# =============================================================================
# AWS (S3 document storage + SES email)
# =============================================================================

# [OPTIONAL] Set to false to disable S3 and use local filesystem instead (dev only)
# AWS_ENABLED=true

# [SECRET] AWS access key ID
# For production, prefer IAM roles attached to EC2/ECS instead of static keys
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY_ID

# [SECRET] AWS secret access key
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_ACCESS_KEY

# [REQUIRED] AWS region for all services
AWS_REGION=ap-south-1

# [REQUIRED] S3 bucket for document storage (PDF, generated documents)
# Bucket must exist and have appropriate IAM permissions
S3_BUCKET_NAME=nlc-documents

# [REQUIRED] S3 bucket for backups (activity log archives)
S3_BACKUP_BUCKET=nlc-backups

# [OPTIONAL] Pre-signed URL expiry in seconds (default: 3600 = 1 hour)
S3_PRESIGNED_URL_EXPIRE_SECONDS=3600

# [OPTIONAL] Key prefix for documents in S3
S3_DOCUMENT_PREFIX=documents/

# [REQUIRED] SES region (may differ from main AWS region)
SES_REGION=ap-south-1

# [REQUIRED] From address for outbound email (must be verified in SES)
EMAIL_FROM=compliance@neumlexcounsel.com

# [OPTIONAL] Reply-to address
EMAIL_REPLY_TO=support@neumlexcounsel.com


# =============================================================================
# AI PROVIDER (Document Drafting)
# =============================================================================

# [REQUIRED] Which AI provider to use for document drafting
# Values: openai | anthropic | local_llm
AI_PROVIDER=anthropic

# [SECRET] OpenAI API key (required if AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# [SECRET] Anthropic API key (required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_API_KEY

# [OPTIONAL] Local LLM base URL (required if AI_PROVIDER=local_llm)
# LOCAL_LLM_BASE_URL=http://ollama:11434/v1
# LOCAL_LLM_MODEL=llama3.1:8b

# [OPTIONAL] AI API request timeout in seconds
AI_REQUEST_TIMEOUT_SECONDS=60

# [OPTIONAL] Max retries for AI API calls
AI_MAX_RETRIES=3


# =============================================================================
# WHATSAPP NOTIFICATIONS (Optional)
# =============================================================================

# [OPTIONAL] Enable WhatsApp notifications via WhatsApp Business API
WHATSAPP_ENABLED=false

# [SECRET] WhatsApp Business API access token (required if WHATSAPP_ENABLED=true)
# WHATSAPP_API_TOKEN=CHANGE_ME

# [OPTIONAL] WhatsApp Business API URL
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# [OPTIONAL] WhatsApp Phone Number ID from Meta Business Manager
# WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME


# =============================================================================
# RULE ENGINE
# =============================================================================

# [OPTIONAL] Rule engine version (semantic version, shown in score hash)
RULE_ENGINE_VERSION=1.0.0

# [OPTIONAL] ILRMF framework version
ILRMF_VERSION=1.0.0


# =============================================================================
# CRON SCHEDULES (UTC times)
# =============================================================================

# [OPTIONAL] Daily compliance evaluation time (24h UTC, format: "HH:MM")
# Default: "00:00" (midnight UTC = 06:00 Bangladesh Standard Time)
CRON_DAILY_EVAL_TIME=00:00

# [OPTIONAL] Deadline warning days (comma-separated, how many days before deadline to warn)
# Default: 30,15,7,3,1
CRON_DEADLINE_WARNING_DAYS=30,15,7,3,1

# [OPTIONAL] Monthly score snapshot day (1-28, day of month)
CRON_SCORE_SNAPSHOT_DAY=1


# =============================================================================
# PDF GENERATION (WeasyPrint)
# =============================================================================

# [OPTIONAL] Path to font files inside container
PDF_FONT_PATH=/app/static/fonts

# [OPTIONAL] Path to PDF HTML templates
PDF_TEMPLATE_PATH=/app/templates/pdf

# [OPTIONAL] Max document size in MB
DOCUMENT_MAX_SIZE_MB=10


# =============================================================================
# PAGINATION
# =============================================================================

# [OPTIONAL] Default page size for list endpoints
DEFAULT_PAGE_SIZE=25

# [OPTIONAL] Maximum allowed page size
MAX_PAGE_SIZE=100
